# Required for the agent
ANTHROPIC_API_KEY=

# Optional model overrides (defaults work with current Anthropic model IDs)
CLAUDE_MODEL_FAST=claude-3-5-haiku-20241022
CLAUDE_MODEL_SMART=claude-sonnet-4-20250514

# ElevenLabs (primary TTS). If unset, Piper is required.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_OUTPUT_FORMAT=pcm_22050
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Piper fallback TTS (paths to binary and ONNX model)
PIPER_EXECUTABLE=piper
PIPER_MODEL_PATH=

# Voice capture / VAD (webrtcvad + sounddevice @ 16 kHz mono)
VAD_AGGRESSIVENESS=2
VAD_SILENCE_SECONDS=1.2

# faster-whisper (voice stack pins base.en in code; keep aligned here)
WHISPER_MODEL_SIZE=base.en

# Data layout
# Example: C:\Users\YourName\.jarvis
DATA_DIR=C:\jarvis\data
CHROMA_PATH=C:\jarvis\chroma
# Profile SQLite (default: <DATA_DIR>/jarvis.db)
SQLITE_PATH=C:\jarvis\data\jarvis.db

# Google Calendar + Gmail (OAuth desktop client JSON)
GOOGLE_CREDENTIALS_PATH=C:\jarvis\google\credentials.json
GOOGLE_TOKEN_PATH=C:\jarvis\google\token.json

# Briefing / Open-Meteo
OPEN_METEO_USER_AGENT=JARVIS-local-assistant/0.1
BRIEFING_NEWS_RSS_URLS=https://feeds.bbci.co.uk/news/rss.xml

# Optional JSON map of friendly app name → executable for launch_app (merged with defaults)
APP_LAUNCH_ALIASES_JSON={"chrome":"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"}

# Logging
LOG_LEVEL=INFO